{
  "manifest_version": 3,
  "name": "Aperfeicoar Mensagens IA",
  "description": "Aperfeicoe mensagens em conversas, e-mails e redes sociais com IA, estilos e controle de uso.",
  "version": "1.0.0",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.whatsotimizado.com.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "externally_connectable": {
    "matches": [
      "https://api.whatsotimizado.com.br/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/premium-symbol.png"],
      "matches": [
        "https://web.whatsapp.com/*",
        "https://mail.google.com/*",
        "https://www.instagram.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*",
        "https://mail.google.com/*",
        "https://www.instagram.com/*"
      ],
      "js": ["config.js", "content-script.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Aperfeicoar Mensagens IA",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  }
}
